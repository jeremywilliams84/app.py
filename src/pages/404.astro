---
import Layout from '../layouts/Layout.astro';
import { getServices } from '../utils/content-generator';

const services = getServices();
---

<Layout
  title="Page non trouvée - 404 | LocalServices"
  description="La page que vous recherchez n'existe pas. Retrouvez nos services de plomberie et électricité."
  noindex={true}
>
  <div class="container error-page">
    <div class="error-content">
      <h1>404</h1>
      <h2>Page non trouvée</h2>
      <p>
        Désolé, la page que vous recherchez n'existe pas ou a été déplacée.
      </p>

      <div class="error-actions">
        <a href="/" class="btn btn-primary">Retour à l'accueil</a>
        <a href="/contact/" class="btn btn-outline">Nous contacter</a>
      </div>

      <div class="error-suggestions">
        <h3>Vous cherchez peut-être :</h3>
        <div class="suggestions-grid">
          {services.map(service => (
            <a href={`/${service.slug}/`} class="suggestion-card">
              <span class="suggestion-icon">{service.icon}</span>
              <span>{service.namePlural}</span>
            </a>
          ))}
          <a href="/villes/" class="suggestion-card">
            <span class="suggestion-icon">📍</span>
            <span>Toutes les villes</span>
          </a>
          <a href="/departements/" class="suggestion-card">
            <span class="suggestion-icon">🗺️</span>
            <span>Tous les départements</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .error-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1rem;
  }

  .error-content h1 {
    font-size: 8rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1;
  }

  .error-content h2 {
    margin-top: 0;
  }

  .error-content > p {
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .error-suggestions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .error-suggestions h3 {
    margin-bottom: 1rem;
  }

  .suggestions-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .suggestion-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s;
  }

  .suggestion-card:hover {
    background: var(--color-primary);
    color: white;
    text-decoration: none;
  }

  .suggestion-icon {
    font-size: 1.25rem;
  }
</style>
